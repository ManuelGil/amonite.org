---
import '../styles/global.css';
import SiteNav from '../components/site/SiteNav.astro';
import SiteFooter from '../components/site/SiteFooter.astro';
import BaseHead from '../components/BaseHead.astro';
import StructuredData from '../components/StructuredData.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import type { ImageMetadata } from 'astro';

export interface Props {
  title: string;
  description?: string;
  image?: ImageMetadata | string;
  structuredData?: Record<string, unknown>[];
}

const { title, description = SITE_DESCRIPTION, image, structuredData = [] } = Astro.props;
const pageTitle = title === SITE_TITLE ? title : `${title} · ${SITE_TITLE}`;

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_TITLE,
  url: Astro.site?.toString(),
  description: SITE_DESCRIPTION,
};
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={pageTitle} description={description} image={image} />
    <StructuredData item={websiteSchema} />
    {structuredData.map((item) => <StructuredData item={item} />)}
  </head>
  <body class="flex min-h-screen flex-col bg-mist text-graphite">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:bg-mist focus:px-3 focus:py-2 focus:text-sm focus:text-graphite">
      Skip to content
    </a>
    <SiteNav />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
