---
import Layout from '../layouts/Layout.astro';
import ActionLink from '../components/site/ActionLink.astro';
import CapabilityIndex from '../components/site/CapabilityIndex.astro';
import DownloadPanel from '../components/site/DownloadPanel.astro';
import ProjectSupport from '../components/site/ProjectSupport.astro';
import Screenshot from '../components/site/Screenshot.astro';
import firstBoot from '../assets/screenshots/first-boot.png';
import terminalFastfetch from '../assets/screenshots/terminal-fastfetch.png';
import {
  DISTRIBUTION,
  SITE_DESCRIPTION,
  SOFTWARE_APPLICATION_JSONLD,
} from '../consts';
---

<Layout
  title="Amonite"
  description={SITE_DESCRIPTION}
  image={terminalFastfetch}
  structuredData={[SOFTWARE_APPLICATION_JSONLD]}
>
  <section class="border-b border-border bg-graphite text-mist">
    <div class="mx-auto grid max-w-6xl gap-12 px-6 py-16 sm:py-20 lg:grid-cols-[0.9fr_1.1fr] lg:items-center lg:gap-14 lg:py-24">
      <div>
        <p class="label-mono font-medium text-sand">
          GNU/Linux · {DISTRIBUTION.releaseLabel}
        </p>
        <h1 class="display-serif mt-4 text-5xl leading-none text-mist sm:text-6xl">
          Amonite
        </h1>
        <p class="mt-6 max-w-md text-lg leading-relaxed text-mist/85">
          {DISTRIBUTION.tagline}
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <ActionLink href="/downloads" variant="accent">
            Download {`${DISTRIBUTION.series} ${DISTRIBUTION.stage}`}
          </ActionLink>
          <ActionLink
            href="/gallery"
            variant="secondary"
            class="border-mist/25 bg-transparent text-mist hover:border-mist/50 hover:bg-mist/10"
          >
            See the system
          </ActionLink>
        </div>
        <p class="mt-8 font-mono text-xs leading-relaxed text-mist/50">
          {DISTRIBUTION.isoFileName}<br />
          SHA256 checksum · GPG signature · <a
            href="/downloads#verification"
            class="underline decoration-mist/30 underline-offset-4 hover:text-mist/80"
          >verify before install</a>
        </p>
      </div>

      <Screenshot
        image={terminalFastfetch}
        alt="Maximized terminal on Amonite showing fastfetch output with the Amonite ASCII mark and system details"
        caption={`The terminal after boot: fastfetch reporting ${DISTRIBUTION.name} ${DISTRIBUTION.release} as shipped. Unedited capture from the live ISO.`}
        loading="eager"
        sizes="(max-width: 1024px) 100vw, 40rem"
        captionClass="text-mist/50"
      />
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 py-20 sm:py-24">
    <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center lg:gap-14">
      <div class="lg:order-2">
        <p class="label-mono font-medium text-amber">What it is</p>
        <h2 class="display-serif mt-3 text-2xl text-graphite sm:text-3xl">
          An operating system defined by what it enables
        </h2>
        <p class="mt-5 text-base leading-relaxed text-slate sm:text-lg">
          Amonite is a GNU/Linux operating system you can install today. After installation,
          desktop work, development, administration, networking, and local AI are already
          available.
        </p>
        <p class="mt-4 text-base leading-relaxed text-slate sm:text-lg">
          Amonite starts with a simple rule: software earns its place by enabling work.
        </p>
        <p class="mt-6">
          <ActionLink href="/philosophy" variant="ghost">Why Amonite exists →</ActionLink>
        </p>
      </div>
      <Screenshot
        image={firstBoot}
        alt="Amonite live session at first boot with the Welcome handbook and installer open on an empty desktop"
        caption="First boot of the live session: the Welcome handbook and the installer, nothing else."
        class="lg:order-1"
        sizes="(max-width: 1024px) 100vw, 40rem"
      />
    </div>
  </section>

  <section class="border-y border-border bg-sand/15">
    <div class="mx-auto max-w-6xl px-6 py-20 sm:py-24">
      <div class="max-w-2xl">
        <p class="label-mono font-medium text-amber">Capabilities</p>
        <h2 class="display-serif mt-3 text-2xl text-graphite sm:text-3xl">
          What becomes possible after install
        </h2>
        <p class="mt-4 text-base leading-relaxed text-slate">
          The system is defined by the work it is ready for on day one. Each of these eight
          capabilities has a reason to be here.
        </p>
      </div>
      <CapabilityIndex class="mt-12" />
      <p class="mt-6 text-sm text-slate">
        <ActionLink href="/engineering" variant="ghost">
          How each capability is realized →
        </ActionLink>
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 py-20 sm:py-24">
    <div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-start lg:gap-14">
      <div>
        <p class="label-mono font-medium text-amber">Local Artificial Intelligence</p>
        <h2 class="display-serif mt-3 text-2xl text-graphite sm:text-3xl">
          Inference on your machine
        </h2>
        <p class="mt-4 text-base leading-relaxed text-slate">
          Local AI is one deliberate capability of the platform. It is not a label for the
          whole operating system.
        </p>
        <p class="mt-4 text-base leading-relaxed text-slate">
          Models and prompts stay on your hardware. Nothing depends on an external service.
        </p>
      </div>
      <ul class="divide-y divide-border border-y border-border text-sm leading-relaxed text-slate">
        <li class="py-3">Execute compatible GGUF models locally</li>
        <li class="py-3">Run inference entirely offline</li>
        <li class="py-3">Keep models and prompts under your control</li>
        <li class="py-3">Use an OpenAI-compatible API for local applications</li>
        <li class="py-3">Build workflows without external services</li>
      </ul>
    </div>
  </section>

  <section class="border-t border-border bg-sand/15">
    <div class="mx-auto max-w-6xl px-6 py-14 sm:py-16">
      <DownloadPanel />
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 py-20 sm:py-24">
    <div class="max-w-2xl">
      <p class="label-mono font-medium text-amber">Continue</p>
      <h2 class="display-serif mt-3 text-2xl text-graphite sm:text-3xl">
        Where to go next
      </h2>
    </div>
    <nav aria-label="Site sections" class="mt-10 border-t border-border">
      {
        [
          {
            href: '/philosophy',
            title: 'Philosophy',
            description: 'Why every capability must justify its presence.',
          },
          {
            href: '/engineering',
            title: 'Engineering',
            description: 'How capabilities are realized, and what stays replaceable.',
          },
          {
            href: '/gallery',
            title: 'Gallery',
            description: 'The system as shipped, captured from the live ISO.',
          },
          {
            href: '/community',
            title: 'Community',
            description: 'Discuss on Reddit. Follow releases on GitHub.',
          },
        ].map((item, i) => (
          <a
            href={item.href}
            class="group grid gap-x-8 gap-y-1 border-b border-border py-5 transition-colors hover:bg-sand/15 sm:grid-cols-[4rem_12rem_1fr_auto] sm:items-baseline"
          >
            <span class="font-mono text-sm text-slate/60" aria-hidden="true">
              {String(i + 1).padStart(2, '0')}
            </span>
            <span class="text-base font-semibold tracking-tight text-graphite">
              {item.title}
            </span>
            <span class="text-sm leading-relaxed text-slate">{item.description}</span>
            <span
              class="hidden text-sm font-medium text-amber transition-transform group-hover:translate-x-0.5 sm:inline"
              aria-hidden="true"
            >
              →
            </span>
          </a>
        ))
      }
    </nav>
  </section>

  <ProjectSupport />
</Layout>
