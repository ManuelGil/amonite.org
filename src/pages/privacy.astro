---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/site/PageHeader.astro';
import { COMMUNITY_URL } from '../consts';
---

<Layout title="Privacy" description="Privacy for the Amonite website.">
  <PageHeader eyebrow="Legal" title="Privacy" />
  <article class="mx-auto max-w-2xl px-6 py-16 sm:py-20">
    <div class="space-y-6 text-base leading-relaxed text-slate">
      <p>This site has no accounts, payments, or forms that collect personal information.</p>
      <p>The host may process ordinary request data under its own practices. External links follow those services’ policies.</p>
      <p>
        Questions about the project belong on{' '}
        <a href={COMMUNITY_URL} class="text-graphite underline decoration-border underline-offset-[5px] hover:decoration-slate">r/amonite</a>.
      </p>
    </div>
  </article>
</Layout>
