---
import Layout from '../layouts/Layout.astro';
import ActionLink from '../components/site/ActionLink.astro';
import PageHeader from '../components/site/PageHeader.astro';
import { DISTRIBUTION, SOFTWARE_APPLICATION_JSONLD } from '../consts';

const { validatedConfiguration, releaseHistory } = DISTRIBUTION;

const configuration = [
  { label: 'Architecture', value: validatedConfiguration.architecture },
  { label: 'CPU', value: validatedConfiguration.cpu },
  { label: 'Memory', value: validatedConfiguration.memory },
  { label: 'Storage', value: validatedConfiguration.storage },
  { label: 'Firmware', value: validatedConfiguration.firmware },
  { label: 'Virtualization platform', value: validatedConfiguration.virtualization },
  { label: 'Installed system size', value: validatedConfiguration.installedSize },
];

const iso = DISTRIBUTION.isoFileName;
const verifyCommands = `# Compute the checksum of the downloaded image
sha256sum ${iso}

# Compare it with the published value
cat ${iso}.sha256

# Verify the detached GPG signatures
gpg --verify ${iso}.asc ${iso}
gpg --verify amonite-${DISTRIBUTION.release}.json.asc amonite-${DISTRIBUTION.release}.json`;
---

<Layout
  title="Downloads"
  description={`Prepare to download, verify, and install Amonite ${DISTRIBUTION.series} ${DISTRIBUTION.stage}.`}
  structuredData={[SOFTWARE_APPLICATION_JSONLD]}
>
  <PageHeader
    eyebrow="Downloads"
    title="Make Amonite your system."
    lead={`Get ${DISTRIBUTION.name} ${DISTRIBUTION.series} ${DISTRIBUTION.stage} ready to install. Check your hardware, download the release, verify it, then install.`}
  />

  <article class="mx-auto max-w-6xl space-y-20 px-6 py-16 sm:space-y-24 sm:py-20">
    <section class="border border-border bg-sand/15 p-8 sm:p-10">
      <div class="grid gap-8 lg:grid-cols-[1fr_auto] lg:items-end lg:gap-12">
        <div>
          <p class="label-mono font-medium text-amber">Current release</p>
          <h2 class="mt-3 text-2xl font-semibold tracking-tight text-graphite sm:text-3xl">
            {DISTRIBUTION.releaseLabel}
          </h2>
          <p class="mt-3 max-w-2xl text-base leading-relaxed text-slate">
            {`${DISTRIBUTION.releaseSummary} This is Alpha software.`}
          </p>
          <dl class="mt-8 grid gap-4 border-t border-border pt-6 sm:grid-cols-4">
            <div>
              <dt class="text-sm text-slate">Series</dt>
              <dd class="mt-1 font-mono text-sm font-medium text-graphite">
                {DISTRIBUTION.series}
              </dd>
            </div>
            <div>
              <dt class="text-sm text-slate">Stage</dt>
              <dd class="mt-1 font-mono text-sm font-medium text-graphite">
                {DISTRIBUTION.stage}
              </dd>
            </div>
            <div>
              <dt class="text-sm text-slate">Version</dt>
              <dd class="mt-1 font-mono text-sm font-medium text-graphite">
                {DISTRIBUTION.release}
              </dd>
            </div>
            <div>
              <dt class="text-sm text-slate">Release date</dt>
              <dd class="mt-1 font-mono text-sm font-medium text-graphite">
                {DISTRIBUTION.releaseDate}
              </dd>
            </div>
          </dl>
        </div>
        <div class="flex flex-col items-stretch gap-3 lg:items-end lg:pb-1">
          <ActionLink href={DISTRIBUTION.isoUrl} external>
            Download ISO
          </ActionLink>
          <p class="font-mono text-center text-xs text-slate lg:text-right">
            Direct download · {DISTRIBUTION.isoFileName}
          </p>
          <ActionLink href={DISTRIBUTION.artifacts.releaseNotes.href} variant="ghost" external>
            Release notes and verification files
          </ActionLink>
        </div>
      </div>
    </section>

    <section class="grid gap-10 lg:grid-cols-2 lg:gap-16">
      <div>
        <h2 class="text-xl font-semibold tracking-tight text-graphite sm:text-2xl">
          Validated configuration
        </h2>
        <p class="mt-3 text-base leading-relaxed text-slate">
          {`The configuration used to validate the current ${DISTRIBUTION.series} ${DISTRIBUTION.stage} release. A practical reference, not a statement of minimum or recommended requirements.`}
        </p>
        <table class="mt-8 w-full border-t border-border text-sm">
          <caption class="sr-only">Validated hardware configuration</caption>
          <tbody>
            {
              configuration.map((row) => (
                <tr class="border-b border-border">
                  <th scope="row" class="py-3 pr-6 text-left font-normal text-slate">
                    {row.label}
                  </th>
                  <td class="py-3 text-right font-mono text-[0.8125rem] text-graphite">
                    {row.value}
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
      <div>
        <h2 class="text-xl font-semibold tracking-tight text-graphite sm:text-2xl">
          Validation results
        </h2>
        <p class="mt-3 text-base leading-relaxed text-slate">
          Before publishing, we exercised these paths on the validated configuration. Every item
          below passed.
        </p>
        <ul class="mt-8 grid gap-x-8 gap-y-2 border-t border-border pt-6 text-sm leading-relaxed text-slate sm:grid-cols-2">
          {
            validatedConfiguration.results.map((result) => (
              <li class="flex gap-2">
                <span class="font-mono text-amber" aria-hidden="true">✓</span>
                {result}
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <section id="verification">
      <h2 class="text-xl font-semibold tracking-tight text-graphite sm:text-2xl">
        Verification
      </h2>
      <p class="mt-3 max-w-2xl text-base leading-relaxed text-slate">
        Every release includes a SHA256 checksum, detached GPG signatures, and signed
        release metadata. Verify them before writing installation media, so the image is
        complete and came from the project. The signing key is published with the release.
      </p>
      <pre
        class="mt-8 overflow-x-auto border border-border bg-graphite p-6 font-mono text-[0.8125rem] leading-relaxed text-mist"><code>{verifyCommands}</code></pre>
      <p class="mt-4 text-sm leading-relaxed text-slate">
        All verification files are published alongside the ISO on the
        <a
          href={DISTRIBUTION.artifacts.iso.href}
          class="text-graphite underline decoration-border underline-offset-[5px] hover:decoration-slate"
        >current GitHub Release</a>.
      </p>
    </section>

    <section class="grid gap-8 md:grid-cols-2">
      <div class="border border-border bg-sand/15 p-8 sm:p-10">
        <h2 class="text-xl font-semibold tracking-tight text-graphite">Installation</h2>
        <p class="mt-3 text-base leading-relaxed text-slate">
          Write the verified image to a USB drive, boot it, and follow the graphical
          installer. The Installation Guide covers writing media, starting the installer,
          and setting up the system.
        </p>
        <div class="mt-6">
          <ActionLink href={DISTRIBUTION.artifacts.installGuide.href} external>
            Read Installation Guide
          </ActionLink>
        </div>
      </div>

      <div class="border border-border bg-sand/15 p-8 sm:p-10">
        <h2 class="text-xl font-semibold tracking-tight text-graphite">
          Before you commit a disk
        </h2>
        <p class="mt-3 text-base leading-relaxed text-slate">
          The live session runs entirely from the USB drive, so you can evaluate the
          system without touching installed disks. The installer only changes a disk when
          you confirm the partitioning step.
        </p>
        <div class="mt-6">
          <ActionLink href="/gallery" variant="secondary">
            See the installer in the gallery
          </ActionLink>
        </div>
      </div>
    </section>

    <section>
      <h2 class="text-xl font-semibold tracking-tight text-graphite sm:text-2xl">
        Release history
      </h2>
      <p class="mt-3 max-w-2xl text-base leading-relaxed text-slate">
        Previous releases remain available through GitHub. The list will grow as releases
        are published.
      </p>
      <ul class="mt-8 divide-y divide-border border-y border-border">
        {
          releaseHistory.map((release) => (
            <li class="flex flex-col gap-3 py-5 sm:flex-row sm:items-center sm:justify-between">
              <div class="flex items-baseline gap-4">
                <p class="font-medium text-graphite">{release.label}</p>
                <p class="font-mono text-sm text-slate">{release.version}</p>
              </div>
              {
                release.version === DISTRIBUTION.release ? (
                  <p class="label-mono text-amber">Current release</p>
                ) : (
                  <ActionLink href={release.href} variant="ghost" external>
                    Open release
                  </ActionLink>
                )
              }
            </li>
          ))
        }
      </ul>
    </section>
  </article>
</Layout>
