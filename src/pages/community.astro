---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import ActionLink from '../components/site/ActionLink.astro';
import PageHeader from '../components/site/PageHeader.astro';
import ProjectSupport from '../components/site/ProjectSupport.astro';
import {
  COMMUNITY_URL,
  DISTRIBUTION,
  SOURCE_URL,
} from '../consts';
import workspaceImage from '../assets/img/workspace.jpg';

const channels = [
  {
    name: 'Reddit',
    role: 'Questions, feedback, and discussion',
    detail: `r/amonite is the primary public space for conversation about running ${DISTRIBUTION.series} ${DISTRIBUTION.stage}: installs, what works, and where friction remains.`,
    href: COMMUNITY_URL,
    linkLabel: 'Open r/amonite',
    external: true,
  },
  {
    name: 'GitHub',
    role: 'Releases and project documentation',
    detail:
      'Releases, checksums, signatures, and public documentation for the current stage are published on GitHub.',
    href: SOURCE_URL,
    linkLabel: 'Open GitHub',
    external: true,
  },
  {
    name: 'The system itself',
    role: 'The primary source',
    detail: `The fastest way to form an opinion is to install ${DISTRIBUTION.series} and use it.`,
    href: '/downloads',
    linkLabel: 'Downloads',
    external: false,
  },
];
---

<Layout
  title="Community"
  description="Discuss Amonite on r/amonite. Follow releases and project documentation on GitHub."
>
  <PageHeader
    eyebrow="Community"
    title="Public discussion is the support channel"
    lead="Questions and feedback belong on Reddit, where the conversation stays public and useful to others. Releases and project documentation are published on GitHub."
  />

  <article class="mx-auto max-w-6xl px-6 py-16 sm:py-20">
    <section class="grid gap-8 pb-16 lg:grid-cols-[0.8fr_1.2fr] lg:items-end lg:gap-14">
      <figure>
        <Image
          src={workspaceImage}
          alt="Quiet workstation beside a window with a monitor, keyboard, and speakers"
          class="h-72 w-full object-cover object-center sm:h-80 lg:h-96"
          width={1200}
          sizes="(max-width: 1024px) 100vw, 28rem"
          quality={82}
          format="webp"
        />
        <figcaption class="mt-3 text-xs leading-relaxed text-slate">
          A place to use the system, then bring what you learn back to the project.
        </figcaption>
      </figure>
      <p class="max-w-xl text-lg leading-relaxed text-slate">
        Start with a question, a fresh install, or something that does not work as expected.
        The useful part is what can be shared afterward.
      </p>
    </section>

    <div class="border-t border-border">
      {
        channels.map((channel, i) => (
          <section class="grid gap-x-8 gap-y-3 border-b border-border py-8 sm:grid-cols-[4rem_14rem_1fr_auto] sm:items-start sm:py-10">
            <span class="font-mono text-sm text-slate/60" aria-hidden="true">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div>
              <h2 class="text-base font-semibold tracking-tight text-graphite">
                {channel.name}
              </h2>
              <p class="label-mono mt-1 text-amber">{channel.role}</p>
            </div>
            <p class="max-w-xl text-sm leading-relaxed text-slate">{channel.detail}</p>
            <ActionLink
              href={channel.href}
              variant="secondary"
              external={channel.external}
              class="justify-self-start sm:justify-self-end"
            >
              {channel.linkLabel}
            </ActionLink>
          </section>
        ))
      }
    </div>
  </article>

  <ProjectSupport />
</Layout>
