---
export interface Props {
  title: string;
  class?: string;
}

const { title, class: className = '' } = Astro.props;
---

<div class:list={['flex h-full flex-col border border-border bg-mist p-6 sm:p-7', className]}>
  <h3 class="text-base font-semibold tracking-tight text-graphite">{title}</h3>
  <div class="mt-3 flex-1 text-sm leading-relaxed text-slate">
    <slot />
  </div>
</div>
