---
/**
 * Authorship and sponsorship. Place after the primary product narrative.
 */
import ActionLink from './ActionLink.astro';
import { SITE_AUTHOR, SPONSORS_URL } from '../../consts';
---

<section class="border-t border-border">
  <div class="mx-auto grid max-w-6xl gap-10 px-6 py-16 sm:py-20 lg:grid-cols-2 lg:gap-14">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.15em] text-amber">Authorship</p>
      <h2 class="mt-3 text-xl font-semibold tracking-tight text-graphite sm:text-2xl">
        An independent project
      </h2>
      <p class="mt-4 text-base leading-relaxed text-slate">
        Amonite is an independent GNU/Linux distribution designed, built, and maintained by {SITE_AUTHOR}.
      </p>
      <p class="mt-4 text-base leading-relaxed text-slate">
        Every release is personally designed, built, tested, and cryptographically signed.
      </p>
    </div>

    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.15em] text-amber">Sponsorship</p>
      <h2 class="mt-3 text-xl font-semibold tracking-tight text-graphite sm:text-2xl">
        Sustaining the work
      </h2>
      <p class="mt-4 text-base leading-relaxed text-slate">
        Sponsorship helps sustain development, testing, infrastructure, hardware, documentation, and long-term maintenance.
      </p>
      <p class="mt-4 text-base leading-relaxed text-slate">
        It is optional, and available through GitHub Sponsors.
      </p>
      <p class="mt-6">
        <ActionLink href={SPONSORS_URL} variant="secondary" external>
          GitHub Sponsors
        </ActionLink>
      </p>
    </div>
  </div>
</section>
