---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

export interface Props {
  href: string;
  title: string;
  description: string;
  image?: ImageMetadata;
  imageAlt?: string;
}

const { href, title, description, image, imageAlt = '' } = Astro.props;
---

<a
  href={href}
  class="flex h-full flex-col overflow-hidden border border-border bg-mist transition-colors hover:border-slate/35"
>
  {
    image && (
      <div class="aspect-[16/10] overflow-hidden bg-sand/30">
        <Image
          src={image}
          alt={imageAlt}
          class="h-full w-full object-cover"
          widths={[400, 640, 900]}
          sizes="(max-width: 768px) 100vw, 33vw"
          quality={72}
          format="webp"
          loading="lazy"
        />
      </div>
    )
  }
  <div class="flex flex-1 flex-col p-6">
    <h3 class="text-base font-semibold tracking-tight text-graphite">{title}</h3>
    <p class="mt-2 flex-1 text-sm leading-relaxed text-slate">{description}</p>
    <span class="mt-4 text-sm font-medium text-amber">Continue →</span>
  </div>
</a>
